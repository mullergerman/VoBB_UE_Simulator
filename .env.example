# Copiar a `.env` (docker compose lo lee solo, incluso con sudo) y ajustar.
#
#   cp .env.example .env && vi .env
#   docker compose --profile ims up -d --build
#
# Ojo: `BIND_ADDR=x sudo docker compose ...` NO funciona, porque sudo limpia el
# entorno. Por eso conviene el .env.

# --- Interfaz de salida (host con varias interfaces virtuales) --------------
# IP local por la que debe salir TODO (SIP, RTP, relay, reg-event). Tiene que
# ser una IP asignada a una interfaz de este host; si no, se ignora y se avisa
# en el log. Vacío => se autodetecta por la ruta hacia el P-CSCF.
BIND_ADDR=
# Alternativa: nombre de interfaz (se lee su IPv4). Se usa sólo si BIND_ADDR
# está vacío.
BIND_IFACE=
# IP a anunciar en el SDP si hay NAT 1:1 delante (normalmente vacío).
MEDIA_PUBLIC_ADDR=

# --- Motor SIP --------------------------------------------------------------
# Relay SIP que unifica el flow de origen en :5060. Dejar en 1.
SIP_RELAY=1
# Suscripción reg-event (RFC 3680) tras el REGISTER.
REG_EVENT_SUBSCRIBE=1
# 4 o más vuelca los mensajes SIP crudos al log.
PJSUA_LOG_LEVEL=4
